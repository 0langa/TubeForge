                                <Path Fill="#FFAD42" Data="M 25,2 L 26,5 L 29,6 L 26,7 L 25,10 L 24,7 L 21,6 L 24,5 Z" />
                            </Grid>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Use TubeForge responsibly" FontSize="24" FontWeight="SemiBold" Margin="0,22,0,0" />
                    <TextBlock Text="TubeForge saves public media locally without ads, tracking, or hosted conversion. You remain responsible for what you download."
                               Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="• Download only media you own or have permission to save."
                               Margin="0,18,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="• Follow copyright, privacy, local law, and applicable service terms."
                               Margin="0,8,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="• TubeForge does not bypass DRM, payments, membership, or access controls."
                               Margin="0,8,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="Acknowledgement is stored only on this device."
                               Margin="0,18,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding ErrorMessage}" Margin="0,12,0,0" TextWrapping="Wrap"
                               Foreground="#FFC4CE"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button x:Name="ResponsibleUseAcceptButton" Style="{StaticResource PrimaryButton}"
                            Content="I understand — continue" Command="{Binding AcceptResponsibleUseCommand}"
                            AutomationProperties.Name="Accept responsible use and continue" Margin="0,22,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
