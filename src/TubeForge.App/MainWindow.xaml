<Window x:Class="TubeForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TubeForge" Icon="Assets/TubeForge.ico" Height="820" Width="1240"
        MinHeight="680" MinWidth="980"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="226" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                IsEnabled="{Binding IsMainContentEnabled}">
            <Grid Margin="20,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource AccentBrush}">
                        <Viewbox Margin="6">
                            <Grid Width="32" Height="32">
                                <Path Fill="White" Data="M 8,5.9 C 7.1,5.5 6.3,6 6.3,6.8 L 6.3,25.2 C 6.3,26 7.2,26.5 7.9,26.1 L 24,16.8 C 24.7,16.4 24.7,15.5 24,15.1 Z" />
                                <Path Fill="#FFAD42" Data="M 25,2 L 26,5 L 29,6 L 26,7 L 25,10 L 24,7 L 21,6 L 24,5 Z" />
                            </Grid>
                        </Viewbox>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TubeForge" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="LOCAL MEDIA TOOL" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="↓   Download" Command="{Binding ShowDownloadCommand}"
                            AutomationProperties.Name="Download page">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDownloadPage}" Value="True">
                                        <Setter Property="Background" Value="#1A2240" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="≡   Queue" Command="{Binding ShowQueueCommand}"
                            AutomationProperties.Name="Download queue page">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQueuePage}" Value="True">
                                        <Setter Property="Background" Value="#1A2240" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="□   Library" Command="{Binding ShowLibraryCommand}"
                            AutomationProperties.Name="Download library page">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLibraryPage}" Value="True">
                                        <Setter Property="Background" Value="#1A2240" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⚙   Settings" Command="{Binding ShowSettingsCommand}"
                            AutomationProperties.Name="Settings page">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                        <Setter Property="Background" Value="#1A2240" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="◇   Diagnostics" Command="{Binding ShowDiagnosticsCommand}"
                            AutomationProperties.Name="Diagnostics page">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiagnosticsPage}" Value="True">
                                        <Setter Property="Background" Value="#1A2240" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border Grid.Row="4" Background="#111A2B" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="RESPONSIBLE USE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" />
                        <TextBlock Text="Save only media you own or have permission to download. No DRM or access-control bypass."
                                   Margin="0,7,0,0" TextWrapping="Wrap" FontSize="11" LineHeight="16"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      IsEnabled="{Binding IsMainContentEnabled}"
                      Visibility="{Binding IsDownloadPage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="38,30,38,40" MaxWidth="1020">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="Download media" FontSize="29" FontWeight="SemiBold" />
                        <TextBlock Text="Analyze a YouTube URL, choose the exact stream, save locally."
                                   Margin="0,7,0,0" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#10251F"
                            BorderBrush="#245E4B" BorderThickness="1" CornerRadius="12" Padding="10,6">
                        <TextBlock Text="●  COMPATIBLE MP4" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" />
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UrlTextBox" Grid.Column="0" Text="{Binding UrlText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="YouTube video, playlist, or channel URL"
                                 AutomationProperties.Name="YouTube video, playlist, or channel URL"
                                 KeyDown="UrlTextBox_OnKeyDown" />
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Analyze"
                                Command="{Binding AnalyzeCommand}" AutomationProperties.Name="Analyze YouTube URL" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}" BorderBrush="#613143"
                        AutomationProperties.LiveSetting="Assertive"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="!" Foreground="{StaticResource ErrorBrush}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding ErrorMessage}" Margin="12,1,0,0" TextWrapping="Wrap"
                                   Foreground="#FFC4CE" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="6" Visibility="{Binding HasVideo, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="#080C14">
                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="18">
                                    <TextBlock Text="{Binding VideoTitle}" FontSize="16" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxHeight="52" />
                                    <TextBlock Text="{Binding VideoMetaLine}" Margin="0,8,0,0" FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                    <Border Background="#1B2335" CornerRadius="6" Padding="8,5" Margin="0,13,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ExtractionStatus}" FontSize="10"
                                                   Foreground="{StaticResource SuccessBrush}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Destination" FontSize="13" FontWeight="SemiBold" />
                                <Grid Margin="0,9,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="74" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding DownloadFolder, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" Padding="10,8" AutomationProperties.Name="Download folder" />
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Browse"
                                            Padding="9,8" Click="BrowseButton_OnClick" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,0"
                                Visibility="{Binding HasCaptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Captions" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Save a manual or auto-generated language track beside the media."
                                           Margin="0,5,0,0" FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="LANGUAGE TRACK" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                <ComboBox ItemsSource="{Binding CaptionTracks}" SelectedItem="{Binding SelectedCaptionTrack}"
                                          AutomationProperties.Name="Caption language and track type" />
                                <TextBlock Text="CAPTION FORMAT" Style="{StaticResource FieldLabel}" Margin="0,12,0,5" />
                                <ComboBox ItemsSource="{Binding CaptionFormats}" SelectedItem="{Binding SelectedCaptionFormat}"
                                          AutomationProperties.Name="Caption output format" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Save caption" Margin="0,12,0,0"
                                        Command="{Binding DownloadCaptionCommand}"
                                        AutomationProperties.Name="Save selected caption" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,0"
                                Visibility="{Binding HasVideo, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Sidecars" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Save the highest thumbnail or a stable JSON metadata record beside the media."
                                           Margin="0,5,0,0" FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Save thumbnail" Margin="0,12,0,0"
                                        Command="{Binding SaveThumbnailCommand}"
                                        AutomationProperties.Name="Save highest quality thumbnail" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Save metadata (.json)" Margin="0,8,0,0"
                                        Command="{Binding SaveMetadataCommand}"
                                        AutomationProperties.Name="Save metadata JSON sidecar" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Build your download" FontSize="17" FontWeight="SemiBold" />
                                    <TextBlock Text="Choose a use case first; only relevant controls stay visible."
                                               Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding FormatCountLabel}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            </Grid>

                            <TextBlock Text="DOWNLOAD TYPE" Style="{StaticResource FieldLabel}" Margin="0,18,0,6" />
                            <ComboBox ItemsSource="{Binding DownloadModes}" SelectedItem="{Binding SelectedDownloadMode}"
                                      AutomationProperties.Name="Download type">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Text="{Binding Description}" Margin="0,3,0,0" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Border Background="#0E1A2B" BorderBrush="#29405F" BorderThickness="1"
                                    CornerRadius="8" Padding="11,9" Margin="0,10,0,0">
                                <TextBlock Text="{Binding ModeNotice}" TextWrapping="Wrap" FontSize="10"
                                           LineHeight="15" Foreground="#A8B7CE" />
                            </Border>

                            <Grid Margin="0,16,0,0"
                                  Visibility="{Binding HasVideoFilters, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="QUALITY" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding ResolutionOptions}" SelectedItem="{Binding SelectedResolution}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Video quality" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="CONTAINER" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding ContainerOptions}" SelectedItem="{Binding SelectedContainer}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Video container" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="VIDEO CODEC" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding VideoCodecOptions}" SelectedItem="{Binding SelectedVideoCodec}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Video codec" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="FRAME RATE" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding FrameRateOptions}" SelectedItem="{Binding SelectedFrameRate}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Frame rate" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <TextBlock Text="DYNAMIC RANGE" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding DynamicRangeOptions}" SelectedItem="{Binding SelectedDynamicRange}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Dynamic range" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0"
                                  Visibility="{Binding IsAudioVideo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="AUDIO QUALITY" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding BitrateOptions}" SelectedItem="{Binding SelectedBitrate}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Muxed audio quality" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="AUDIO CODEC" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding AudioCodecOptions}" SelectedItem="{Binding SelectedAudioCodec}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Muxed audio codec" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0"
                                  Visibility="{Binding IsAudioOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="BITRATE" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding BitrateOptions}" SelectedItem="{Binding SelectedBitrate}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Audio bitrate" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="FILE FORMAT" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding ContainerOptions}" SelectedItem="{Binding SelectedContainer}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Audio file format" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="AUDIO CODEC" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding AudioCodecOptions}" SelectedItem="{Binding SelectedAudioCodec}"
                                              DisplayMemberPath="Label" AutomationProperties.Name="Audio codec" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="PROCESSING" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding AudioProcessingOptions}"
                                              SelectedItem="{Binding SelectedAudioProcessing}"
                                              AutomationProperties.Name="Audio processing" MinHeight="48">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" />
                                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="EXACT OUTPUT" Style="{StaticResource FieldLabel}" Margin="0,16,0,6" />
                            <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}"
                                      AutomationProperties.Name="Exact matching stream" MinHeight="54">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding TechnicalLabel}" Margin="0,3,0,0" FontSize="10"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding SizeLabel}" Margin="14,0,0,0"
                                                       VerticalAlignment="Center" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <ProgressBar Minimum="0" Maximum="1" Value="{Binding DownloadFraction, Mode=OneWay}"
                                         Margin="0,16,0,0"
                                         AutomationProperties.Name="Latest active download progress"
                                         Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" TextTrimming="CharacterEllipsis"
                                               AutomationProperties.LiveSetting="Polite"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding ProgressDetail}" Margin="0,3,0,0" FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Pause all"
                                        Command="{Binding CancelCommand}" Padding="14,10"
                                        Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Grid.Column="4" Style="{StaticResource PrimaryButton}" Content="{Binding DownloadActionLabel}"
                                        Command="{Binding DownloadCommand}" AutomationProperties.Name="Start download" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="6" Style="{StaticResource Card}"
                        Visibility="{Binding HasCollection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="{Binding CollectionTitle}" FontSize="20" FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CollectionSummary}" Margin="0,5,0,0" FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Button Style="{StaticResource SecondaryButton}" Content="Select all" Padding="13,8"
                                        Command="{Binding SelectAllCollectionCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Select none" Padding="13,8"
                                        Margin="8,0,0,0" Command="{Binding SelectNoneCollectionCommand}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Background="#0E1A2B" BorderBrush="#29405F" BorderThickness="1"
                                CornerRadius="8" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="DESTINATION" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding DownloadFolder, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Collection download folder" />
                                <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Content="Browse"
                                        Click="BrowseButton_OnClick" />
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="4" ItemsSource="{Binding CollectionItems}" Height="520"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="Collection videos">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="3,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                                  AutomationProperties.Name="Select collection video" />
                                        <TextBlock Grid.Column="1" Text="{Binding IndexLabel}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Detail}" Margin="0,4,0,0" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding Status}" VerticalAlignment="Center"
                                                   TextAlignment="Right" TextWrapping="Wrap" FontSize="10"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="6" Background="#111A2A" CornerRadius="8" Padding="12,9">
                            <TextBlock Text="Best complete file per video: highest-quality compatible video + audio, MP4 preferred only when quality is equal. Use {index} in the filename template to include collection positions."
                                       TextWrapping="Wrap" FontSize="10" Foreground="#A8B7CE" />
                        </Border>

                        <Grid Grid.Row="8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CollectionSelectionSummary}" FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding ProgressDetail}" Margin="0,3,0,0" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <Button Style="{StaticResource PrimaryButton}" Content="Add selected to queue"
                                    HorizontalAlignment="Right" Width="190"
                                    Command="{Binding QueueCollectionCommand}"
                                    AutomationProperties.Name="Add selected collection videos to queue" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="8" Style="{StaticResource Card}"
                        Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Width="100" IsIndeterminate="True" VerticalAlignment="Center"
                                     AutomationProperties.Name="Analyzing media" />
                        <TextBlock Text="Analyzing YouTube delivery options…" Margin="16,0,0,0"
                                   Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
