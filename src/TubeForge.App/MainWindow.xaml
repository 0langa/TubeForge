                            <Button Grid.Column="4" Style="{StaticResource SecondaryButton}"
                                    Content="Remove missing" Command="{Binding RemoveMissingHistoryCommand}"
                                    Padding="13,9" VerticalAlignment="Bottom" />
                        </Grid>
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="HISTORY STORAGE" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="{Binding HistoryStoragePath}" Margin="0,6,0,0" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasHistory}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" Margin="20">
                        <TextBlock Text="Library empty" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding HistoryEmptyMessage}"
                                   Margin="0,7,0,0" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="6" ItemsSource="{Binding HistoryItems}" Height="600"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         AutomationProperties.Name="Completed download history">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Detail}" Margin="0,5,0,0" FontSize="10"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Destination}" Margin="0,4,0,0" FontSize="9"
                                                   Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Open folder"
                                            Command="{Binding RevealCommand}" Padding="12,8" VerticalAlignment="Center" />
                                    <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Content="Remove record"
                                            Command="{Binding RemoveCommand}" Padding="12,8" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      IsEnabled="{Binding IsMainContentEnabled}"
                      Visibility="{Binding IsQueuePage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="38,30,38,40" MaxWidth="1020">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="Download queue" FontSize="29" FontWeight="SemiBold" />
                        <TextBlock Text="Rate-aware transfers, recovery, and per-item controls."
                                   Margin="0,7,0,0" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding QueueSummary}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GLOBAL CONCURRENCY" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="Global 1–4 · provider host cap 2 · Retry-After honored" Margin="0,4,0,0" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding MaxConcurrentDownloadOptions}"
                                  SelectedItem="{Binding SelectedMaxConcurrentDownloads}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Maximum concurrent downloads" />
                        <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Content="Pause all"
                                Command="{Binding CancelCommand}" Padding="14,10" VerticalAlignment="Center"
                                Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Grid.Column="6" Style="{StaticResource SecondaryButton}" Content="Clear completed"
                                Command="{Binding ClearCompletedCommand}" Padding="14,10" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}" BorderBrush="#613143"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="!" Foreground="{StaticResource ErrorBrush}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding ErrorMessage}" Margin="12,1,0,0" TextWrapping="Wrap"
                                   Foreground="#FFC4CE" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="6">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQueueItems}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" Margin="20">
                        <TextBlock Text="Queue empty" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="Analyze media, choose output, then use Add to queue."
                                   Margin="0,7,0,0" Foreground="{StaticResource MutedTextBrush}" />
                        <Button Style="{StaticResource PrimaryButton}" Content="Add a download" Margin="0,18,0,0"
                                Command="{Binding ShowDownloadCommand}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ItemsControl Grid.Row="8" ItemsSource="{Binding QueueItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FileName}" Margin="0,5,0,0" FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{Binding StatusBackground}" BorderBrush="{Binding StatusBorder}"
                                                BorderThickness="1" CornerRadius="8" Padding="9,5" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                                       Foreground="{Binding StatusForeground}" />
                                        </Border>
                                    </Grid>

                                    <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress, Mode=OneWay}"
                                                 Margin="0,16,0,0" Height="6"
                                                 AutomationProperties.Name="Queued download progress" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProgressDetail}" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Text="{Binding DestinationDirectory}" Margin="0,3,0,0" FontSize="9"
                                                       Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="{Binding ResumeLabel}"
                                                Command="{Binding ResumeCommand}" Padding="12,8"
                                                Visibility="{Binding CanResume, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Content="Pause"
                                                Command="{Binding PauseCommand}" Padding="12,8"
                                                Visibility="{Binding CanPause, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Grid.Column="5" Style="{StaticResource SecondaryButton}" Content="Cancel"
                                                Command="{Binding CancelCommand}" Padding="12,8"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Grid.Column="7" Style="{StaticResource SecondaryButton}" Content="Open folder"
                                                Command="{Binding RevealCommand}" Padding="12,8" />
                                        <Button Grid.Column="9" Style="{StaticResource SecondaryButton}" Content="Remove"
                                                Command="{Binding RemoveCommand}" Padding="12,8"
                                                Visibility="{Binding CanRemove, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      IsEnabled="{Binding IsMainContentEnabled}"
                      Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="38,30,38,40" MaxWidth="1020">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Settings" FontSize="29" FontWeight="SemiBold" />
                    <TextBlock Text="Local defaults. No account, cloud sync, or telemetry."
                               Margin="0,7,0,0" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource Card}" BorderBrush="#613143"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" Foreground="#FFC4CE" />
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Download defaults" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="Used for new queue items. Existing destinations stay unchanged."
                                   Margin="0,5,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />

                        <TextBlock Text="DEFAULT DOWNLOAD FOLDER" Style="{StaticResource FieldLabel}" Margin="0,20,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DownloadFolder, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Default download folder" />
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Browse"
                                    Click="BrowseButton_OnClick" />
                        </Grid>

                        <TextBlock Text="FILENAME TEMPLATE" Style="{StaticResource FieldLabel}" Margin="0,18,0,6" />
                        <TextBox Text="{Binding FileNameTemplateText, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Filename template" />
                        <TextBlock Text="{}Tokens: {title}, {channel}, {videoId}, {quality}, {container}, {index}. Double braces print a literal brace. Default collection names keep their source index."
                                   Margin="0,6,0,0" FontSize="10" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />

                        <TextBlock Text="MAXIMUM CONCURRENT DOWNLOADS" Style="{StaticResource FieldLabel}" Margin="0,18,0,6" />
                        <ComboBox ItemsSource="{Binding MaxConcurrentDownloadOptions}"
                                  SelectedItem="{Binding SelectedMaxConcurrentDownloads}" Width="160"
                                  HorizontalAlignment="Left" AutomationProperties.Name="Default maximum concurrent downloads" />
                        <TextBlock Text="Requests to one provider host are capped at two and pause on server rate-limit guidance."
                                   Margin="0,6,0,0" FontSize="10" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />

                        <CheckBox IsChecked="{Binding EnableAcceleratedTransfers}" Margin="0,20,0,0"
                                  AutomationProperties.Name="Enable accelerated transfers">
                            <StackPanel>
                                <TextBlock Text="Accelerated transfers" FontWeight="SemiBold" />
                                <TextBlock Text="Use up to four validated parallel range workers for large files. Falls back automatically when unsupported."
                                           Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </CheckBox>

                        <Border Background="#0E1A2B" BorderBrush="#29405F" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="OUTPUT PREFERENCE" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="MP4 preferred when video quality is equal; higher-quality WebM remains available."
                                           Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#A8B7CE" />
                                <TextBlock Text="FFmpeg stream-copies video/audio tracks into indexed MP4 or validated WebM/MKV; MP3 output re-encodes audio only. No yt-dlp."
                                           Margin="0,4,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SettingsStatus}" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="Save settings"
                                    Command="{Binding SaveSettingsCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Updates" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="Stable releases are downloaded from the official GitHub repository and verified with two matching SHA-256 records before they can run."
                                   Margin="0,7,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />

                        <CheckBox IsChecked="{Binding EnableAutomaticUpdateChecks}" Margin="0,18,0,0"
                                  AutomationProperties.Name="Automatically check for TubeForge updates">
                            <StackPanel>
                                <TextBlock Text="Automatically check at startup" FontWeight="SemiBold" />
                                <TextBlock Text="Checks release metadata only. Installation always requires your confirmation."
                                           Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </CheckBox>

                        <ProgressBar Height="5" Margin="0,16,0,0" Maximum="1"
                                     Value="{Binding UpdateDownloadFraction, Mode=OneWay}"
                                     Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{Binding UpdateStatus}" Margin="0,14,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Content="Check now"
                                    Command="{Binding CheckForUpdatesCommand}" Padding="14,9" />
                            <Button Style="{StaticResource PrimaryButton}" Content="Download update" Margin="10,0,0,0"
                                    Command="{Binding DownloadUpdateCommand}" Padding="14,9"
                                    Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Style="{StaticResource PrimaryButton}" Content="Install and restart" Margin="10,0,0,0"
                                    Click="InstallUpdateButton_OnClick" Padding="14,9"
                                    Visibility="{Binding IsUpdateReady, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="8" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Privacy and responsibility" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="Settings, queue state, and completed-output history stay in local application data. Media URLs, cookies, signatures, visitor data, and telemetry are not persisted."
                                   Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="Download only media you own or have permission to save. TubeForge does not bypass DRM, payment, membership, or access controls."
                                   Margin="0,7,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      IsEnabled="{Binding IsMainContentEnabled}"
                      Visibility="{Binding IsDiagnosticsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="38,30,38,40" MaxWidth="1020">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Diagnostics" FontSize="29" FontWeight="SemiBold" />
                    <TextBlock Text="Local runtime and extraction health. Sensitive media URLs are never shown."
