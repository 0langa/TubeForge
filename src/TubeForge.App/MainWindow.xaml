                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="Library" FontSize="29" FontWeight="SemiBold" />
                        <TextBlock Text="Durable local history powers duplicate detection. No media URLs are stored."
                                   Margin="0,7,0,0" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding HistorySummary}" HorizontalAlignment="Right"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                        <Button Style="{StaticResource SecondaryButton}" Content="Clear history" Margin="0,9,0,0"
                                Command="{Binding ClearHistoryCommand}" Padding="13,8" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SEARCH LIBRARY" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding LibrarySearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,5,0,0" AutomationProperties.Name="Search completed downloads" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SORT" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding LibrarySortOptions}"
                                          SelectedItem="{Binding SelectedLibrarySort}"
                                          DisplayMemberPath="Label" Margin="0,5,0,0"
                                          AutomationProperties.Name="Sort completed downloads" />
