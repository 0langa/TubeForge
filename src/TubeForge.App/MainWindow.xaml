                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource Card}" BorderBrush="#613143"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" Foreground="#FFC4CE" />
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Runtime" FontSize="17" FontWeight="SemiBold" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="TubeForge version" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding ApplicationVersion}" />
                            <TextBlock Grid.Row="2" Text="Runtime" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RuntimeDescription}" />
                            <TextBlock Grid.Row="4" Text="Architecture" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ProcessArchitecture}" />
                            <TextBlock Grid.Row="6" Text="Dependencies" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DependencyStatus}"
                                       Foreground="{StaticResource SuccessBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Session and local storage" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DiagnosticsExtractionStatus}" Margin="0,14,0,0" />
                        <TextBlock Text="{Binding DiagnosticsFormatSummary}" Margin="0,5,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding QueueSummary}" Margin="0,5,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" />

                        <TextBlock Text="QUEUE STATE" Style="{StaticResource FieldLabel}" Margin="0,20,0,5" />
                        <TextBlock Text="{Binding QueueStoragePath}" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="LIBRARY HISTORY" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                        <TextBlock Text="{Binding HistoryStoragePath}" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="SETTINGS" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                        <TextBlock Text="{Binding SettingsStoragePath}" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DiagnosticsStatus}" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Copy report"
                                    Click="CopyDiagnosticsButton_OnClick" Padding="14,9"
                                    AutomationProperties.Name="Copy redacted diagnostic report" />
                            <Button Grid.Column="3" Style="{StaticResource PrimaryButton}" Content="Export JSON"
                                    Click="ExportDiagnosticsButton_OnClick" Padding="14,9"
                                    AutomationProperties.Name="Export redacted diagnostic report as JSON" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

