<Window x:Class="TubeForge.Installer.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TubeForge Setup" Icon="Assets/TubeForge.ico"
        Width="620" Height="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Image Source="Assets/TubeForge.png" Width="72" Height="72" />
            <StackPanel Margin="20,4,0,0">
                <TextBlock Text="TubeForge" FontSize="28" FontWeight="Bold" />
                <TextBlock x:Name="VersionText" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="18" Padding="24">
            <StackPanel>
                <TextBlock x:Name="HeadingText" FontSize="21" FontWeight="SemiBold" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" LineHeight="21"
                           Text="Installs for your Windows account only. Includes pinned LGPL FFmpeg for reliable video muxing and local audio conversion. No administrator rights, service, PATH change, or advertising." />
                <TextBlock Margin="0,20,0,5" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"
                           Text="INSTALL LOCATION" />
                <TextBlock x:Name="InstallPathText" TextWrapping="Wrap" />
                <ProgressBar x:Name="Progress" Height="7" Margin="0,24,0,0" IsIndeterminate="True"
                             Visibility="Collapsed" Foreground="{StaticResource AccentBrush}" />
                <TextBlock x:Name="StatusText" Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}"
                           Text="Ready" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Click="Cancel_OnClick"
                    Padding="22,11" Background="#1A2740" Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}" />
            <Button x:Name="ActionButton" Grid.Column="3" Click="Action_OnClick" Padding="28,11"
                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" />
        </Grid>
    </Grid>
</Window>
