<Application x:Class="TubeForge.Installer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#080C14" />
        <SolidColorBrush x:Key="CardBrush" Color="#111A2B" />
        <SolidColorBrush x:Key="BorderBrush" Color="#293754" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9DB4DF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7957F6" />
    </Application.Resources>
</Application>
